pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
metadata:
  labels:
    jenkins: agent
spec:
  serviceAccountName: jenkins-sa
  containers:
  - name: gcloud
    image: google/cloud-sdk:latest
    command:
    - cat
    tty: true
  - name: kaniko
    image: gcr.io/kaniko-project/executor:latest
    args:
    - --dockerfile=/workspace/Dockerfile
    - --context=/workspace
    - --destination=us-central1-docker.pkg.dev/${project_id}/sofe3980u/binarycalculatorwebapp:latest
    - --single-snapshot
    volumeMounts:
    - name: workspace-volume
      mountPath: /workspace
  volumes:
  - name: workspace-volume
    emptyDir: {}
"""
        }
    }

    environment {
        project_id   = credentials('project_id')
        repo_path    = credentials('repo_path')
        cluster_name = credentials('cluster_name')
        cluster_zone = credentials('cluster_zone')
    }

    stages {

        stage('test') {
            steps {
                container('gcloud') {
                    sh 'mvn clean test -f ./BinaryCalculatorWebApp/pom.xml'
                }
            }
        }

        stage('build') {
            steps {
                container('gcloud') {
                    sh 'mvn -f ./BinaryCalculatorWebApp/pom.xml -DskipTests clean package'
                }
            }
        }

        stage('containerize') {
            steps {
                container('gcloud') {
                    sh """
                        gcloud config set project ${project_id}
                        gcloud auth configure-docker us-central1-docker.pkg.dev --quiet
                    """
                }

                container('kaniko') {
                    sh """
                        cp -r BinaryCalculatorWebApp/* /workspace/
                    """
                }
            }
        }

        stage('deploy') {
            steps {
                container('gcloud') {
                    sh """
                        gcloud container clusters get-credentials ${cluster_name} \
                            --zone ${cluster_zone} --project ${project_id}

                        kubectl delete deployment binarycalculatorwebapp --ignore-not-found
                        kubectl apply -f k8s-deployment.yaml
                    """
                }
            }
        }

        stage('service') {
            steps {
                container('gcloud') {
                    sh """
                        kubectl apply -f k8s-service.yaml
                        kubectl get svc binarycalculatorwebapp-service
                    """
                }
            }
        }
    }
}
